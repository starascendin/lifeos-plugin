{
  "name": "@starascendin/lifeos-plugin",
  "version": "1.3.0",
  "description": "LifeOS agent plugin with skills, MCP tools, workflow prompts, and CLI helpers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lifeos-mcp": "dist/index.js",
    "lifeos": "dist/cli.js"
  },
  "files": [
    ".claude-plugin",
    ".mcp.json.example",
    "config",
    "dist",
    "scripts",
    "skills",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/generate-build-info.mjs && tsc",
    "dev:mcp": "tsx src/index.ts",
    "dev:cli": "tsx src/cli.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "keywords": [
    "lifeos",
    "claude-plugin",
    "mcp",
    "model-context-protocol",
    "productivity",
    "project-management",
    "life-design",
    "convex"
  ],
  "author": "Bryan Liu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starascendin/lifeos-plugin.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
